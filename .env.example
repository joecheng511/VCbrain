DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/dealbrain
GEMINI_API_KEY=AIza...
GEMINI_MODEL=gemini-2.0-flash
# Comma-separated allowed CORS origins. Use * for local dev only.
CORS_ORIGINS=*
DB_POOL_MIN=2
DB_POOL_MAX=10
# Set to true to auto-start harness evolution when the server boots.
HARNESS_AUTO_RUN=false
HARNESS_MAX_ITERATIONS=5
